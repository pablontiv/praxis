roadmap-root: docs/epics

# Valores de estado que indican trabajo terminado (se EXCLUYEN de vistas pendientes)
done-statuses:
  - Completed
  - Obsolete

# Valores de estado que indican trabajo ejecutable (se INCLUYEN en queries de tasks)
active-statuses:
  - Pending
  - Specified
  - In Progress

# Tipos que son contenedores, no tasks hoja (se EXCLUYEN de listados de tasks)
container-types:
  - feature
  - historia
